{
  "name": "coffee-shop-test-suite",
  "version": "1.0.0",
  "description": "Sprint1 自動化測試",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest --coverage",
    "test:api": "jest tests/api.test.js",
    "test:search": "jest tests/search.test.js",
    "test:auth": "jest tests/auth.test.js",
    "test:frontend": "jest tests/frontend.test.js",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --detectOpenHandles"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "leaflet": "^1.9.4",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "axios": "^1.15.0",
    "jest": "^29.7.0",
    "puppeteer": "^21.11.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "pages/**/*.js",
      "pages/**/*.jsx",
      "components/**/*.js",
      "components/**/*.jsx",
      "!pages/**/*.test.js",
      "!components/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
